{
    "buildCommand": "npm install --legacy-peer-deps && npm run build",
    "outputDirectory": "dist/cafeteria-web/browser/browser",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://cafeteria-gourmet-mio.vercel.app/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}